generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_OWNER
  BRANCH_MANAGER
  CASHIER
  INVENTORY_MANAGER
  WAREHOUSE_MANAGER
  ACCOUNTANT
  HR
  DELIVERY_STAFF
  CUSTOMER
  VENDOR
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
  RETURNED
}

enum PaymentMethod {
  CASH
  CARD
  QR_PAYMENT
  ESEWA
  KHALTI
  BANK_TRANSFER
  SPLIT_PAYMENT
}

enum PurchaseStatus {
  PENDING
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
  RETURNED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  LEAVE
  HOLIDAY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum MembershipTier {
  SILVER
  GOLD
  DIAMOND
  VIP
}

enum NotificationType {
  LOW_STOCK
  EXPIRY
  NEW_ORDER
  PAYMENT_DUE
  PROMOTION
  SYSTEM
}

enum StockMovementType {
  IN
  OUT
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
  RETURN
  DAMAGE
}

// ==================== COMPANY & BRANCH ====================
model Company {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  logo      String?
  panNo     String?
  regNo     String?
  website   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches      Branch[]
  users         User[]
  warehouses    Warehouse[]
  customers     Customer[]
  suppliers     Supplier[]
  settings      CompanySettings?
  products      Product[]
  categories    Category[]
  brands        Brand[]
  taxRates      TaxRate[]
  loyaltyPoints LoyaltyPoint[]
  coupons       Coupon[]
}

model CompanySettings {
  id             String  @id @default(cuid())
  companyId      String  @unique
  company        Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  currency       String  @default("NPR")
  timezone       String  @default("Asia/Kathmandu")
  dateFormat     String  @default("YYYY-MM-DD")
  taxType        String  @default("VAT")
  taxRate        Float   @default(13)
  defaultProfitMargin Float @default(20)
  lowStockThreshold Int @default(10)
  expiryWarningDays Int @default(30)
  enableLoyalty  Boolean @default(true)
  enableGiftCard Boolean @default(false)
  enableMultiCurrency Boolean @default(false)
  language       String  @default("en")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Branch {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  code      String   @unique
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  warehouses   Warehouse[]
  sales        Sale[]
  purchases    Purchase[]
  expenses     Expense[]
  posSessions  PosSession[]
  stockCounts  StockCount[]
}

// ==================== AUTH & USERS ====================
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  firstName      String
  lastName       String
  phone          String?
  avatar         String?
  role           UserRole @default(CASHIER)
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId       String?
  branch         Branch?  @relation(fields: [branchId], references: [id])
  isActive       Boolean  @default(true)
  emailVerified  Boolean  @default(false)
  twoFactorEnabled Boolean @default(false)
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  employee            Employee?
  permissions         UserPermission[]
  loginHistory        LoginHistory[]
  sales               Sale[]            @relation("CashierSales")
  purchases           Purchase[]        @relation("CreatedPurchases")
  attendance          Attendance[]
  leaves              Leave[]
  approvedLeaves      Leave[]           @relation("ApprovedLeaves")
  payrolls            Payroll[]
  stockAdjustments    StockAdjustment[]
  stockCounts         StockCount[]
  posSessions         PosSession[]
  notifications       Notification[]
  sentTransfers       StockTransfer[]   @relation("SenderTransfers")
  receivedTransfers   StockTransfer[]   @relation("ReceiverTransfers")
}

model UserPermission {
  id         String @id @default(cuid())
  userId     String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module     String
  action     String
  createdAt  DateTime @default(now())

  @@unique([userId, module, action])
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  device    String?
  browser   String?
  location  String?
  success   Boolean  @default(true)
  loginAt   DateTime @default(now())
}

// ==================== PRODUCT ====================
model Category {
  id          String     @id @default(cuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  image       String?
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  products Product[]

  @@unique([companyId, slug])
}

model Brand {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  description String?
  image     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@unique([companyId, slug])
}

model TaxRate {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  rate      Float
  type      String   @default("VAT")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Product {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])
  brandId         String?
  brand           Brand?   @relation(fields: [brandId], references: [id])
  taxRateId       String?
  taxRate         TaxRate? @relation(fields: [taxRateId], references: [id])

  name            String
  slug            String
  description     String?
  sku             String   @unique
  barcode         String?  @unique
  qrCode          String?
  unit            String   @default("pcs")
  purchasePrice   Float    @default(0)
  sellingPrice    Float    @default(0)
  wholesalePrice  Float?
  discountPrice   Float?
  taxType         String   @default("exclusive")
  taxAmount       Float    @default(0)

  weight          Float?
  height          Float?
  width           Float?
  length          Float?

  minStock        Int      @default(0)
  maxStock        Int?
  isActive        Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  trackSerial     Boolean  @default(false)
  trackBatch      Boolean  @default(false)
  trackExpiry     Boolean  @default(false)
  warrantyPeriod  Int?
  warrantyType    String?

  images          String?
  tags            String?
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  variants        ProductVariant[]
  batchStock      BatchStock[]
  serialNumbers   SerialNumber[]
  stock           Stock[]
  saleItems       SaleItem[]
  purchaseItems   PurchaseItem[]
  stockAdjustments StockAdjustment[]
  stockCounts     StockCount[]
  priceHistories  PriceHistory[]
}

model ProductVariant {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name           String
  sku            String   @unique
  barcode        String?
  attributes     Json?
  purchasePrice  Float    @default(0)
  sellingPrice   Float    @default(0)
  wholesalePrice Float?
  stock          Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  saleItems      SaleItem[]
  purchaseItems  PurchaseItem[]
}

model PriceHistory {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  oldPrice   Float
  newPrice   Float
  changedBy  String
  reason     String?
  createdAt  DateTime @default(now())
}

// ==================== INVENTORY ====================
model Warehouse {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId   String?
  branch     Branch?  @relation(fields: [branchId], references: [id])
  name       String
  code       String   @unique
  address    String?
  city       String?
  type       String   @default("main")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  stock           Stock[]
  batchStock      BatchStock[]
  stockMovements  StockMovement[]
  incomingTransfers StockTransfer[] @relation("ToWarehouse")
  outgoingTransfers StockTransfer[] @relation("FromWarehouse")
}

model Stock {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  quantity    Int      @default(0)
  reservedQty Int      @default(0)
  minStock    Int      @default(0)
  maxStock    Int?
  shelfLife   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, warehouseId])
}

model BatchStock {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId    String
  warehouse      Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  batchNo        String
  quantity       Int      @default(0)
  purchasePrice  Float    @default(0)
  sellingPrice   Float    @default(0)
  mfgDate        DateTime?
  expDate        DateTime?
  receivedDate   DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([productId, warehouseId, batchNo])
}

model SerialNumber {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  serialNo      String   @unique
  status        String   @default("available")
  warehouseId   String?
  purchaseId    String?
  saleId        String?
  soldAt        DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model StockMovement {
  id          String            @id @default(cuid())
  productId   String
  warehouseId String
  warehouse   Warehouse        @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  type        StockMovementType
  quantity    Int
  reference   String?
  referenceId String?
  note        String?
  createdAt   DateTime         @default(now())
  createdById String?
}

model StockAdjustment {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId   String
  oldQuantity   Int
  newQuantity   Int
  difference    Int
  reason        String
  note          String?
  createdAt     DateTime @default(now())
  createdById   String?
  createdBy     User?    @relation(fields: [createdById], references: [id])
}

model StockTransfer {
  id              String   @id @default(cuid())
  referenceNo     String   @unique
  fromWarehouseId String
  fromWarehouse   Warehouse @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String
  toWarehouse     Warehouse @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  status          String   @default("pending")
  sentById        String?
  sentBy          User?    @relation("SenderTransfers", fields: [sentById], references: [id])
  receivedById    String?
  receivedBy      User?    @relation("ReceiverTransfers", fields: [receivedById], references: [id])
  note            String?
  sentAt          DateTime?
  receivedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items StockTransferItem[]
}

model StockTransferItem {
  id           String   @id @default(cuid())
  transferId   String
  transfer     StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId    String
  variantId    String?
  quantity     Int
  batchNo      String?
  createdAt    DateTime @default(now())
}

model StockCount {
  id          String   @id @default(cuid())
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  warehouseId String
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  systemQty   Int
  physicalQty Int
  difference  Int
  note        String?
  countedById String?
  countedBy   User?    @relation(fields: [countedById], references: [id])
  countedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
}

// ==================== POINT OF SALE ====================
model PosSession {
  id          String   @id @default(cuid())
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  cashierId   String
  cashier     User     @relation(fields: [cashierId], references: [id])
  openingBal  Float    @default(0)
  closingBal  Float?
  cashSales   Float    @default(0)
  cardSales   Float    @default(0)
  otherSales  Float    @default(0)
  status      String   @default("open")
  openedAt    DateTime @default(now())
  closedAt    DateTime?
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sales Sale[]
}

model Sale {
  id            String      @id @default(cuid())
  invoiceNo     String      @unique
  branchId      String
  branch        Branch      @relation(fields: [branchId], references: [id])
  posSessionId  String?
  posSession    PosSession? @relation(fields: [posSessionId], references: [id])
  cashierId     String
  cashier       User        @relation("CashierSales", fields: [cashierId], references: [id])
  customerId    String?
  customer      Customer?   @relation(fields: [customerId], references: [id])
  status        SaleStatus  @default(COMPLETED)
  saleType      String      @default("retail")
  subtotal      Float       @default(0)
  discountTotal Float       @default(0)
  taxTotal      Float       @default(0)
  shippingTotal Float       @default(0)
  grandTotal    Float       @default(0)
  paidAmount    Float       @default(0)
  changeAmount  Float       @default(0)
  dueAmount     Float       @default(0)
  paymentMethod PaymentMethod @default(CASH)
  paymentDetails Json?
  notes         String?
  posData       Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items           SaleItem[]
  payments        SalePayment[]
  saleReturns     SaleReturn[]
  loyaltyEarned   LoyaltyPoint[]
}

model SaleItem {
  id             String   @id @default(cuid())
  saleId         String
  sale           Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  variantId      String?
  variant        ProductVariant? @relation(fields: [variantId], references: [id])
  batchNo        String?
  serialNo       String?
  quantity       Int      @default(1)
  unitPrice      Float    @default(0)
  discount       Float    @default(0)
  discountPercent Float   @default(0)
  taxRate        Float    @default(0)
  taxAmount      Float    @default(0)
  total          Float    @default(0)
  createdAt      DateTime @default(now())
}

model SalePayment {
  id            String        @id @default(cuid())
  saleId        String
  sale          Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  method        PaymentMethod
  amount        Float
  referenceNo   String?
  cardLastFour  String?
  bankName      String?
  chequeNo      String?
  notes         String?
  createdAt     DateTime      @default(now())
}

model SaleReturn {
  id          String   @id @default(cuid())
  saleId      String
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  returnNo    String   @unique
  reason      String
  status      String   @default("pending")
  totalRefund Float    @default(0)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items SaleReturnItem[]
}

model SaleReturnItem {
  id            String   @id @default(cuid())
  returnId      String
  returnRef     SaleReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  saleItemId    String
  quantity      Int
  refundAmount  Float
  reason        String?
  createdAt     DateTime @default(now())
}

// ==================== PURCHASE ====================
model Purchase {
  id              String         @id @default(cuid())
  purchaseOrderNo String         @unique
  branchId        String
  branch          Branch         @relation(fields: [branchId], references: [id])
  supplierId      String?
  supplier        Supplier?      @relation(fields: [supplierId], references: [id])
  createdById     String?
  createdBy       User?          @relation("CreatedPurchases", fields: [createdById], references: [id])
  status          PurchaseStatus @default(PENDING)
  orderDate       DateTime       @default(now())
  expectedDate    DateTime?
  receivedDate    DateTime?
  subtotal        Float          @default(0)
  discountTotal   Float          @default(0)
  taxTotal        Float          @default(0)
  shippingTotal   Float          @default(0)
  grandTotal      Float          @default(0)
  paidAmount      Float          @default(0)
  dueAmount       Float          @default(0)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  items        PurchaseItem[]
  payments     PurchasePayment[]
  goodsReceipt GoodsReceipt[]
  returns      PurchaseReturn[]
}

model PurchaseItem {
  id             String   @id @default(cuid())
  purchaseId     String
  purchase       Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  variantId      String?
  variant        ProductVariant? @relation(fields: [variantId], references: [id])
  quantity       Int      @default(1)
  receivedQty    Int      @default(0)
  unitPrice      Float    @default(0)
  discount       Float    @default(0)
  taxRate        Float    @default(0)
  taxAmount      Float    @default(0)
  total          Float    @default(0)
  batchNo        String?
  mfgDate        DateTime?
  expDate        DateTime?
  createdAt      DateTime @default(now())
}

model PurchasePayment {
  id          String        @id @default(cuid())
  purchaseId  String
  purchase    Purchase      @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  method      PaymentMethod
  amount      Float
  referenceNo String?
  notes       String?
  paidAt      DateTime      @default(now())
  createdAt   DateTime      @default(now())
}

model GoodsReceipt {
  id              String   @id @default(cuid())
  purchaseId      String
  purchase        Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  receiptNo       String   @unique
  warehouseId     String
  receivedById    String?
  notes           String?
  receivedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  items GoodsReceiptItem[]
}

model GoodsReceiptItem {
  id             String   @id @default(cuid())
  goodsReceiptId String
  goodsReceipt   GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  purchaseItemId String
  quantity       Int
  batchNo        String?
  mfgDate        DateTime?
  expDate        DateTime?
  serialNumbers  Json?
  createdAt      DateTime @default(now())
}

model PurchaseReturn {
  id          String   @id @default(cuid())
  purchaseId  String
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  returnNo    String   @unique
  reason      String
  status      String   @default("pending")
  totalRefund Float    @default(0)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items PurchaseReturnItem[]
}

model PurchaseReturnItem {
  id              String   @id @default(cuid())
  returnId        String
  returnRef       PurchaseReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  purchaseItemId  String
  quantity        Int
  refundAmount    Float
  reason          String?
  createdAt       DateTime @default(now())
}

// ==================== CUSTOMER ====================
model Customer {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code            String   @unique
  firstName       String
  lastName        String
  email           String?
  phone           String
  address         String?
  city            String?
  state           String?
  country         String?
  dob             DateTime?
  anniversary     DateTime?
  gender          String?
  photo           String?
  creditLimit     Float    @default(0)
  currentBalance  Float    @default(0)
  totalPurchases  Float    @default(0)
  totalVisits     Int      @default(0)
  lastVisitAt     DateTime?
  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sales         Sale[]
  loyaltyPoints LoyaltyPoint[]
  memberships   Membership[]
  customerNotes CustomerNote[]
}

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  note       String
  createdById String?
  createdAt  DateTime @default(now())
}

model Membership {
  id              String         @id @default(cuid())
  customerId      String
  customer        Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tier            MembershipTier @default(SILVER)
  cardNo          String?        @unique
  points          Int            @default(0)
  totalSpent      Float          @default(0)
  startedAt       DateTime       @default(now())
  expiresAt       DateTime?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model LoyaltyPoint {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  saleId     String?
  sale       Sale?    @relation(fields: [saleId], references: [id])
  points     Int
  type       String   @default("earned")
  reference  String?
  expiresAt  DateTime?
  createdAt  DateTime @default(now())
}

model Coupon {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code        String   @unique
  type        String   @default("percentage")
  value       Float
  minPurchase Float    @default(0)
  maxDiscount Float?
  usageLimit  Int?
  usedCount   Int      @default(0)
  isActive    Boolean  @default(true)
  startsAt    DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== SUPPLIER ====================
model Supplier {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code         String   @unique
  name         String
  contactPerson String?
  email        String?
  phone        String
  alternatePhone String?
  address      String?
  city         String?
  state        String?
  country      String?
  panNo        String?
  website      String?
  paymentTerms String?
  creditLimit  Float?
  currentBalance Float  @default(0)
  totalPurchases Float @default(0)
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchases  Purchase[]
  documents  SupplierDocument[]
}

model SupplierDocument {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  type       String
  title      String
  fileUrl    String
  createdAt  DateTime @default(now())
}

// ==================== EMPLOYEE ====================
model Employee {
  id            String   @id @default(cuid())
  companyId     String
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  employeeCode  String   @unique
  department    String?
  designation   String?
  joiningDate   DateTime @default(now())
  exitDate      DateTime?
  employmentType String  @default("permanent")
  salary        Float    @default(0)
  dailyWage     Float?
  commissionRate Float   @default(0)
  bankName      String?
  bankAccount   String?
  panNo         String?
  emergencyContact String?
  emergencyPhone String?
  documents     Json?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  attendances Attendance[]
  leaves      Leave[]
  payrolls    Payroll[]
}

model Attendance {
  id         String           @id @default(cuid())
  employeeId String
  employee   Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  userId     String
  user       User             @relation(fields: [userId], references: [id])
  date       DateTime
  clockIn    DateTime?
  clockOut   DateTime?
  status     AttendanceStatus @default(PRESENT)
  note       String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([employeeId, date])
}

model Leave {
  id          String       @id @default(cuid())
  employeeId  String
  employee    Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  type        String       @default("annual")
  startDate   DateTime
  endDate     DateTime
  totalDays   Int
  reason      String
  status      LeaveStatus  @default(PENDING)
  approvedById String?
  approvedBy  User?        @relation("ApprovedLeaves", fields: [approvedById], references: [id])
  note        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Payroll {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  periodStart     DateTime
  periodEnd       DateTime
  basicSalary     Float    @default(0)
  allowances      Float    @default(0)
  deductions      Float    @default(0)
  commission      Float    @default(0)
  bonus           Float    @default(0)
  taxDeduction    Float    @default(0)
  netSalary       Float    @default(0)
  paymentStatus   String   @default("pending")
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==================== ACCOUNTING ====================
model Account {
  id          String   @id @default(cuid())
  companyId   String
  code        String
  name        String
  type        String
  description String?
  parentId    String?
  parent      Account? @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    Account[] @relation("AccountHierarchy")
  isActive    Boolean  @default(true)
  balance     Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  journalEntries JournalEntry[]
  transactions   Transaction[]

  @@unique([companyId, code])
}

model Transaction {
  id          String   @id @default(cuid())
  companyId   String
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id])
  type        String
  amount      Float
  description String?
  reference   String?
  referenceId String?
  date        DateTime @default(now())
  createdById String?
  createdAt   DateTime @default(now())
}

model JournalEntry {
  id          String   @id @default(cuid())
  companyId   String
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id])
  entryNo     String   @unique
  type        String
  amount      Float
  description String
  reference   String?
  referenceId String?
  entryDate   DateTime @default(now())
  createdById String?
  createdAt   DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id])
  category    String
  amount      Float
  description String?
  referenceNo String?
  paidBy      String?
  receipt     String?
  expenseDate DateTime @default(now())
  createdAt   DateTime @default(now())
  createdById String?
}

// ==================== NOTIFICATION ====================
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  reference String?
  referenceId String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
}

model NotificationTemplate {
  id        String   @id @default(cuid())
  companyId String
  type      String
  subject   String?
  message   String
  channels  String   @default("in_app")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== SYSTEM & AUDIT ====================
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  module    String
  entity    String?
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model ApiKey {
  id        String   @id @default(cuid())
  companyId String
  name      String
  key       String   @unique
  scopes    String?
  isActive  Boolean  @default(true)
  expiresAt DateTime?
  lastUsedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Backup {
  id        String   @id @default(cuid())
  companyId String?
  fileUrl   String
  size      Int
  type      String   @default("manual")
  status    String   @default("completed")
  notes     String?
  createdAt DateTime @default(now())
}

model SystemSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
